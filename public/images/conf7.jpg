</script><!-- Dark Mode Theme Initialization --><script>
  (function () {
    // Get theme from localStorage or session, default to 'light'
    const storedTheme = localStorage.getItem('theme') || 'light';
    const sessionTheme = '';

    const getPreferredTheme = () => {
      if (sessionTheme && sessionTheme !== 'auto') {
        // Map dark_mode to dark, light_mode to light
        if (sessionTheme === 'dark_mode') return 'dark';
        if (sessionTheme === 'light_mode') return 'light';
        return sessionTheme;
      }
      if (storedTheme) {
        // Handle stored theme values
        if (storedTheme === 'dark_mode') return 'dark';
        if (storedTheme === 'light_mode') return 'light';
        return storedTheme;
      }
      // Default to light, but check system preference for auto mode
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };

    const setTheme = function (theme) {
      const root = document.documentElement;
      if (theme === 'auto' || theme === '') {
        theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      // Set data-bs-theme attribute for Bootstrap dark mode
      root.setAttribute('data-bs-theme', theme);

      // Also add/remove dark-theme class for additional styling
      // Check if body exists before accessing classList
      if (document.body) {
        if (theme === 'dark') {
          document.body.classList.add('dark-theme');
        } else {
          document.body.classList.remove('dark-theme');
        }
      } else {
        // If body doesn't exist yet, wait for DOM to load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () {
            if (theme === 'dark') {
              document.body.classList.add('dark-theme');
            } else {
              document.body.classList.remove('dark-theme');
            }
          });
        }
      }
    };

    // Initialize theme on page load - wait for DOM if needed
    function initializeTheme() {
      const initialTheme = getPreferredTheme();
      setTheme(initialTheme);
    }

    initializeTheme();

    // Listen for system theme changes
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      const currentTheme = localStorage.getItem('theme') || sessionTheme || 'light';
      if (currentTheme === 'auto' || !currentTheme || currentTheme === '') {
        setTheme(getPreferredTheme());
      }
    });
  })();
</script></head><body class="body"><div class="single-layout"><div class="single-layout-row w-row"><div class="single-layout-col left w-col w-col-4"><div class="single-layout-left"><a href="/" class="single-layout-logo w-inline-block"><img src="/assets/images/logo-light.png" width="100" alt="" /></a><div><h4 class="white">Welcome onboard!</h4><p class="white text-large">
